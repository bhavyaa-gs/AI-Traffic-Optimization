{
  "entities": {
    "traffic_data": {
      "title": "Traffic Data",
      "description": "Historical and live traffic data points",
      "type": "object",
      "properties": {
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          },
          "required": ["lat", "lng"]
        },
        "density": { "type": "number", "description": "Vehicle density per km" },
        "speed": { "type": "number", "description": "Average speed in km/h" },
        "congestionLevel": { "type": "string", "enum": ["Low", "Medium", "High"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["location", "density", "speed", "congestionLevel", "timestamp"]
    },
    "accident_logs": {
      "title": "Accident Log",
      "description": "Detected accidents and anomalies",
      "type": "object",
      "properties": {
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          },
          "required": ["lat", "lng"]
        },
        "severity": { "type": "string", "enum": ["Minor", "Major", "Critical"] },
        "status": { "type": "string", "enum": ["Detected", "Responding", "Resolved"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "description": { "type": "string" }
      },
      "required": ["location", "severity", "status", "timestamp"]
    },
    "users": {
      "title": "User Profile",
      "description": "User account information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/traffic_data/{dataId}": {
      "schema": "traffic_data",
      "description": "Collection of traffic data points"
    },
    "/accident_logs/{logId}": {
      "schema": "accident_logs",
      "description": "Collection of accident logs"
    },
    "/users/{userId}": {
      "schema": "users",
      "description": "User profiles"
    }
  }
}
