// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: traffic_data
// Document ID: {dataId}
// Fields:
//   - location: map (required) { lat: number, lng: number }
//   - density: number (required)
//   - speed: number (required)
//   - congestionLevel: string (required, enum: ["Low", "Medium", "High"])
//   - timestamp: timestamp (required)
//
// Collection: accident_logs
// Document ID: {logId}
// Fields:
//   - location: map (required) { lat: number, lng: number }
//   - severity: string (required, enum: ["Minor", "Major", "Critical"])
//   - status: string (required, enum: ["Detected", "Responding", "Resolved"])
//   - timestamp: timestamp (required)
//   - description: string (optional)
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - uid: string (required)
//   - email: string (required, format: email)
//   - displayName: string (optional)
//   - role: string (required, enum: ["admin", "user"])
//   - createdAt: timestamp (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "gsbhavya920@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidTrafficData(data) {
      return data.location is map &&
             data.location.lat is number &&
             data.location.lng is number &&
             data.density is number &&
             data.speed is number &&
             data.congestionLevel in ['Low', 'Medium', 'High'] &&
             data.timestamp is timestamp;
    }

    function isValidAccidentLog(data) {
      return data.location is map &&
             data.location.lat is number &&
             data.location.lng is number &&
             data.severity in ['Minor', 'Major', 'Critical'] &&
             data.status in ['Detected', 'Responding', 'Resolved'] &&
             data.timestamp is timestamp;
    }

    function isValidUser(data) {
      return data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'user'] &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if isAdmin() || (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role);
    }

    match /traffic_data/{dataId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidTrafficData(request.resource.data);
      allow update: if isAdmin() && isValidTrafficData(request.resource.data);
      allow delete: if isAdmin();
    }

    match /accident_logs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidAccidentLog(request.resource.data);
      allow update: if isAdmin() && isValidAccidentLog(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
